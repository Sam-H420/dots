{
    "$schema": "/etc/xdg/swaync/configschema.json",
    "positionX": "right",
    "positionY": "top",
    "cssPriority": "user",
    "control-center-width": 300,
    "control-center-height": 500,
    "fit-to-screen": false,

    "notification-window-width": 250,
    "notification-icon-size": 40,
    "notification-body-image-height": 300,
    "notification-body-image-width": 300,
    "notification-inline-replies": true,
    "notification-2fa-action": false,
  
    "timeout": 3,
    "timeout-low": 2,
    "timeout-critical": 6,
    
    "keyboard-shortcuts": true,
    "image-visibility": "when-available",
    "transition-time": 200,
    "hide-on-clear": false,
    "hide-on-action": false,
    "script-fail-notify": true,

    "widgets": [
      "mpris",
      "buttons-grid",
      "backlight",
      "volume",
      "dnd",
      "notifications"
    ],
   
    "widget-config": {
        "backlight": {
            "device": "intel_backlight",
            "label": "󰃠",
            "slider": true,
            "min": 10
        },
        "volume": {
            "device": "default",
            "label": "󰕾",
            "slider": true
        },

        "dnd": {
            "text": "Do not disturb"
        },

        "mpris": {
            "image-size": 100,
            "image-radius": 10,
            "autohide": false,
            "blacklist": [ "org.mpris.MediaPlayer2.playerctld"]
        },

        "buttons-grid": {
            "actions": [
                {
                    "label": "",
                    "command": "poweroff"
                }
            ]
        }
    }
  }